# Copy to .env and adjust as needed
BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://restful-booker.herokuapp.com
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
LOCKED_USER=locked_out_user
LOCKED_PASSWORD=secret_sauce

# Public Restful Booker demo credentials; override if running against another env.
BOOKER_USERNAME=admin
BOOKER_PASSWORD=password123

# UI Scout (optional) — npm run test:scout
# SCOUT_START_PATH=/inventory.html
# SCOUT_MAX_PAGES=20
# SCOUT_VIEWPORTS=mobile,tablet,desktop
# SCOUT_EXCLUDE=logout
# SCOUT_SCREENSHOTS=true

# UI Scout (exploratory crawl) — optional overrides
# SCOUT_START_PATH=/inventory.html
# SCOUT_MAX_PAGES=20
# SCOUT_VIEWPORTS=mobile,tablet,desktop
# SCOUT_EXCLUDE=logout
# SCOUT_SCREENSHOTS=true
