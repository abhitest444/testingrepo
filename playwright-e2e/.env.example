# Copy to .env and adjust as needed
BASE_URL=https://www.saucedemo.com
API_BASE_URL=https://restful-booker.herokuapp.com
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
LOCKED_USER=locked_out_user
LOCKED_PASSWORD=secret_sauce

# Public Restful Booker demo credentials; override if running against another env.
BOOKER_USERNAME=admin
BOOKER_PASSWORD=password123

# UI Scout — point at any site
# BASE_URL=https://your-app.example.com
# SCOUT_AUTH=none          # none | form | sauce (auto if unset)
# SCOUT_START_PATH=/
# SCOUT_SEED_PATHS=/,/about
# SCOUT_MAX_PAGES=20
# SCOUT_VIEWPORTS=mobile,tablet,desktop
# SCOUT_EXCLUDE=logout,reset,sign-out
# SCOUT_MAX_CLICKS=12
# SCOUT_SCREENSHOTS=true
# SCOUT_A11Y=true
# SCOUT_A11Y_STRICT=false
# SCOUT_VISUAL=true
# SCOUT_UPDATE_BASELINES=false
# SCOUT_VISUAL_THRESHOLD=0.01
# SCOUT_UI_PORT=4177

# Generic form login (SCOUT_AUTH=form)
# SCOUT_LOGIN_PATH=/login
# SCOUT_USERNAME=qa.user
# SCOUT_PASSWORD=secret
# SCOUT_USER_SELECTOR=input[name=email]
# SCOUT_PASSWORD_SELECTOR=input[name=password]
# SCOUT_SUBMIT_SELECTOR=button[type=submit]
# SCOUT_SUCCESS_URL=dashboard
# SCOUT_SUCCESS_SELECTOR=
