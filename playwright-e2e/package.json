{
  "name": "playwright-e2e",
  "version": "1.0.0",
  "description": "Playwright TypeScript e2e framework — Page Objects, fixtures, storageState, API, and a11y coverage",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:smoke": "playwright test --grep @smoke",
    "test:e2e": "playwright test --project=chromium",
    "test:api": "playwright test --project=api",
    "test:a11y": "playwright test --grep @a11y --project=chromium",
    "test:unauthenticated": "playwright test --project=unauthenticated",
    "test:chromium": "playwright test --project=chromium --project=unauthenticated --project=api",
    "report": "playwright show-report",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "playwright",
    "e2e",
    "qa",
    "automation",
    "api-testing",
    "accessibility",
    "ui-scout",
    "crawl"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@playwright/test": "^1.54.1",
    "@types/node": "^22.16.5",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "dotenv": "^16.6.1",
    "pixelmatch": "^5.3.0",
    "pngjs": "^7.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3"
  }
}
